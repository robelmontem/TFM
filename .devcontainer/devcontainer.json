{
    "name": "Blackwell-Dev-Env",
    "image": "nvcr.io/nvidia/pytorch:25.02-py3",
    "runArgs": [
        "--gpus",
        "all",
        "--shm-size=16g"
    ],
    "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
    },
    "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
    ]
}